<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_ticket">

    <fragment
        android:id="@+id/navigation_ticket"
        android:name="com.ticket12306.android.ui.main.TicketFragment"
        android:label="@string/search">
        <action
            android:id="@+id/action_navigation_ticket_to_ticketDetailFragment"
            app:destination="@id/ticketDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_navigation_ticket_to_stationSelectFragment"
            app:destination="@id/stationSelectFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/navigation_booking"
        android:name="com.ticket12306.android.ui.booking.BookingFragment"
        android:label="@string/booking">
        <action
            android:id="@+id/action_navigation_booking_to_bookingConfigFragment"
            app:destination="@id/bookingConfigFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/navigation_order"
        android:name="com.ticket12306.android.ui.order.OrderFragment"
        android:label="@string/my_orders">
        <action
            android:id="@+id/action_navigation_order_to_orderDetailFragment"
            app:destination="@id/orderDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.ticket12306.android.ui.profile.ProfileFragment"
        android:label="@string/profile">
        <action
            android:id="@+id/action_navigation_profile_to_passengerManageFragment"
            app:destination="@id/passengerManageFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_navigation_profile_to_queryHistoryFragment"
            app:destination="@id/queryHistoryFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_navigation_profile_to_settingsFragment"
            app:destination="@id/settingsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_navigation_profile_to_aboutFragment"
            app:destination="@id/aboutFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/ticketDetailFragment"
        android:name="com.ticket12306.android.ui.ticket.TicketDetailFragment"
        android:label="车次详情">
        <action
            android:id="@+id/action_ticketDetailFragment_to_seatSelectFragment"
            app:destination="@id/seatSelectFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/seatSelectFragment"
        android:name="com.ticket12306.android.ui.ticket.SeatSelectFragment"
        android:label="@string/seat_select_title">
        <argument
            android:name="ticketInfo"
            app:argType="com.ticket12306.android.data.model.TicketInfo" />
        <action
            android:id="@+id/action_seatSelectFragment_to_bookingConfigFragment"
            app:destination="@id/bookingConfigFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/stationSelectFragment"
        android:name="com.ticket12306.android.ui.station.StationSelectFragment"
        android:label="选择车站">
        <argument
            android:name="isDeparture"
            app:argType="boolean" />
    </fragment>

    <fragment
        android:id="@+id/bookingConfigFragment"
        android:name="com.ticket12306.android.ui.booking.BookingConfigFragment"
        android:label="抢票配置">
        <argument
            android:name="ticketInfo"
            app:argType="com.ticket12306.android.data.model.TicketInfo"
            app:nullable="true" />
        <argument
            android:name="bookingTask"
            app:argType="com.ticket12306.android.data.model.BookingTask"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/orderDetailFragment"
        android:name="com.ticket12306.android.ui.order.OrderDetailFragment"
        android:label="订单详情">
        <argument
            android:name="orderInfo"
            app:argType="com.ticket12306.android.data.model.OrderInfo" />
    </fragment>

    <fragment
        android:id="@+id/passengerManageFragment"
        android:name="com.ticket12306.android.ui.profile.PassengerManageFragment"
        android:label="乘客管理" />

    <fragment
        android:id="@+id/queryHistoryFragment"
        android:name="com.ticket12306.android.ui.profile.QueryHistoryFragment"
        android:label="查询历史" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.ticket12306.android.ui.profile.SettingsFragment"
        android:label="设置" />

    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.ticket12306.android.ui.profile.AboutFragment"
        android:label="关于" />

</navigation>
