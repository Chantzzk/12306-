<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 查询条件卡片 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- 出发站 - 到达站 行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!-- 出发站 -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/til_from_station"
                                style="@style/TextInputStyle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="@string/departure_station">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_from_station"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:inputType="none"
                                    android:textSize="16sp" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- 交换按钮 -->
                            <ImageButton
                                android:id="@+id/btn_swap"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/swap_stations"
                                android:src="@android:drawable/ic_menu_rotate" />

                            <!-- 到达站 -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/til_to_station"
                                style="@style/TextInputStyle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="@string/arrival_station">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_to_station"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:inputType="none"
                                    android:textSize="16sp" />

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <!-- 日期选择行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!-- 前一天按钮 -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_previous_day"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:minWidth="60dp"
                                android:text="@string/previous_day"
                                android:textColor="@color/date_nav_text"
                                android:textSize="13sp" />

                            <!-- 日期显示 -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/til_date"
                                style="@style/TextInputStyle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:hint="@string/departure_date">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_date"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:inputType="none"
                                    android:textSize="14sp" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- 后一天按钮 -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_next_day"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:minWidth="60dp"
                                android:text="@string/next_day"
                                android:textColor="@color/date_nav_text"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <!-- 日期标签行（今天/明天/后天快捷选择） -->
                        <LinearLayout
                            android:id="@+id/layout_date_tags"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_today"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:text="@string/today"
                                android:textSize="12sp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_tomorrow"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:text="@string/tomorrow"
                                android:textSize="12sp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_day_after_tomorrow"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/day_after_tomorrow"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <!-- 查询按钮 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_search"
                            style="@style/ButtonPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:text="@string/search"
                            android:textSize="16sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- 车次类型筛选 Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_train_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        app:checkedChip="@id/chip_all"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_all"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/filter_all"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_high_speed"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/filter_high_speed"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_electric"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/filter_electric"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_direct"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/filter_direct"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_express"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/filter_express"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_fast"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/filter_fast"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_other"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/filter_other"
                            android:textSize="12sp" />

                    </com.google.android.material.chip.ChipGroup>

                </HorizontalScrollView>

                <!-- 排序与筛选工具栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="4dp">

                    <!-- 结果数量 -->
                    <TextView
                        android:id="@+id/tv_result_count"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/secondary_text"
                        android:textSize="12sp" />

                    <!-- 排序按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_sort_departure"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="0dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="@string/sort_departure_time"
                        android:textColor="@color/secondary_text"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_sort_arrival"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="0dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="@string/sort_arrival_time"
                        android:textColor="@color/secondary_text"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_sort_duration"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="0dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="@string/sort_duration"
                        android:textColor="@color/secondary_text"
                        android:textSize="12sp" />

                    <!-- 筛选按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="0dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="@string/filter_title"
                        android:textColor="@color/primary"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- 骨架屏 -->
                <include
                    android:id="@+id/skeleton_ticket_list"
                    layout="@layout/skeleton_ticket_list" />

                <!-- 车次列表 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="80dp" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- 增强空状态视图 -->
    <include
        android:id="@+id/layout_empty_state"
        layout="@layout/layout_empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
